{
  "name": "dev-toolkits",
  "productName": "Dev Toolkits",
  "version": "0.1.22",
  "description": "Open-source desktop toolkit of commonly used developer utilities (Mermaid renderer, JSON formatter, and more).",
  "main": "dist-electron/main.js",
  "type": "module",
  "bin": {
    "dev-toolkits": "bin/dev-toolkits.js"
  },
  "files": [
    "dist",
    "dist-electron",
    "docs",
    "bin",
    "build"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc -b --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "developer-tools",
    "electron",
    "mermaid",
    "json-formatter",
    "devtools"
  ],
  "author": "Anirban Bhattacherji <anirbanbhattacherji@gmail.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anirbanbhat/dev-toolkits.git"
  },
  "homepage": "https://github.com/anirbanbhat/dev-toolkits",
  "bugs": {
    "url": "https://github.com/anirbanbhat/dev-toolkits/issues"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "diff": "^9.0.0",
    "highlight.js": "^11.11.1",
    "js-md5": "^0.8.3",
    "js-yaml": "^4.1.1",
    "mermaid": "^11.4.1",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "ulid": "^3.0.2",
    "uuid": "^14.0.0"
  },
  "optionalDependencies": {
    "electron": "^33.2.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-md5": "^0.8.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.devtoolkits.app",
    "productName": "Dev Toolkits",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "docs/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "docs",
        "to": "docs"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
